{
  "manifest_version": 3,
  "name": "News Trust Checker",
  "version": "1.0",
  "description": "뉴스 신뢰도 분석 도구",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}